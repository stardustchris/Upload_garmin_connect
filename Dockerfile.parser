FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

# Dependances Python du projet (parser + utilitaires)
COPY requirements.txt /app/requirements.txt
RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir -r /app/requirements.txt

# Code necessaire au parsing
COPY src /app/src
COPY scripts/parse_training_pdf.py /app/scripts/parse_training_pdf.py

ENTRYPOINT ["python", "/app/scripts/parse_training_pdf.py"]
